# Build outputs
bin/
gridsim-client
gridsim-server
/hub
/orchestrator
logs/
run_demo.txt
demo-pis.txt
dashboard.log
text_reader.txt

# Root-level binaries (arm64 builds dropped here by cross-compile workflow)
/evsim
/metersim
/modsim-conformance

# Desktop binaries built locally (make build / go build) — never commit
/dashboard
/httpsim

# Python virtual environment
gui/.venv/

# Private keys — never commit, ever.
# This catches server-key.pem, client-key.pem, vault/ca-key.pem, test keys, all of them.
*-key.pem

# Temporary client cert staging (SCP private key to device, then delete)
certs/client-staging/

# Test cert fixtures (regenerable via `make gen-test-certs`)
# NOTE: was "internal/tlsserver/testdata/certs/" (no such path exists — the
# server package lives at sim/tlsserver) until TASK-003 CI work found the typo
# had let 5 generated cert files get committed under sim/tlsserver/testdata/certs/.
sim/tlsserver/testdata/certs/
internal/tlsclient/testdata/certs/

# Golden files DO get committed — they're part of the test suite
!sim/tlsserver/testdata/golden/

# Bench replay artifacts (per-run, regenerated each replay)
replay-checkpoint.json
replay-ticklog-*.csv

# Mayhem QA run reports (per-run, regenerated each suite run)
qa-mayhem-*.md

# Go test artifacts
*.test
*.out

# Editor cruft
.vscode/
.idea/
*.swp
*~

# python
__pycache__/
*.pyc

# go.work: TASK-024 (AD-003(d)/(e)) retires the committed go.work in favor of
# proto.pin + vendor/lexa-proto/. Developers may still keep an untracked
# local go.work (`go work init . ../lexa-proto`) for cross-repo dev against a
# live lexa-proto checkout — it must never be committed again.
go.work
go.work.sum
.claude/worktrees/
