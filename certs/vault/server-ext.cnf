basicConstraints       = critical,CA:FALSE
keyUsage               = critical,digitalSignature,keyAgreement
extendedKeyUsage       = serverAuth
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid,issuer
subjectAltName         = @san

[san]
DNS.1 = csip-test-server
DNS.2 = localhost
IP.1  = 192.168.0.188
IP.2  = 127.0.0.1
